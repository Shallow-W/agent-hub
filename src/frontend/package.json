{
  "name": "agent-hub-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"npm run dev -- --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "test:electron": "node --test electron/*.test.mjs",
    "build": "tsc -b && vite build",
    "build:electron": "npm run build && electron-builder --dir",
    "preview": "vite preview",
    "test:e2e:agent": "playwright test e2e/agent-connect.spec.ts --browser=chromium"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "antd": "^6.4.3",
    "highlight.js": "^11.11.1",
    "pptx-preview": "^1.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^38.8.6",
    "electron-builder": "^26.15.2",
    "jsdom": "^29.1.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.agenthub.desktop",
    "productName": "AgentHub",
    "directories": {
      "output": "../../.tmp/electron-release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "!electron/*.test.mjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../bin",
        "to": "bin"
      },
      {
        "from": "dist",
        "to": "frontend-dist"
      },
      {
        "from": "../backend/config/config.example.yaml",
        "to": "config/config.yaml"
      }
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false,
      "signExecutable": false
    }
  }
}
